---
import Layout from '../../layouts/Layout.astro';
import BlogCard from '../../components/BlogCard.astro';

// Mock Data (In a real app, this might come from Markdown/CMS)
const posts = [
  {
    title: "Why Child Vaccination is Important? {Complete Guide}",
    excerpt: "Discover the critical role vaccines play in protecting your child's health, common myths debunked, and why sticking to the schedule is vital.",
    date: "May 6, 2026",
    image: "/images/blog/Why Child Vaccination is Important.jpg",
    slug: "why-child-vaccination-is-important",
    category: "Immunization",
    content: "Content..."
  }
];
---

<Layout 
  title="Parenting Blog" 
  description="Expert advice and tips on child health, parenting, and nutrition from Dr. Sanjay Swamy."
>
  <div class="page-header">
    <div class="container">
      <h1>Parenting & Health Blog</h1>
      <p>Expert insights for your child's well-being.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="blog-grid">
        {posts.map(post => (
          <BlogCard {...post} />
        ))}
      </div>
    </div>
  </section>

</Layout>

<style>
  .page-header { background-color: var(--color-primary); color: white; padding: 3rem 0; text-align: center; }
  
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
  }
</style>
