---
interface Props {
  title: string;
  excerpt: string;
  date: string;
  image: string;
  slug: string;
  category: string;
}

const { title, excerpt, date, image, slug, category } = Astro.props;
---

<article class="blog-card">
  <a href={`/blog/${slug}`} class="card-image-link">
    <div class="card-image">
      <img src={image} alt={title} loading="lazy" width="400" height="250" />
    </div>
  </a>
  <div class="card-content">
    <span class="date">{date}</span>
    <h3><a href={`/blog/${slug}`}>{title}</a></h3>
    <p>{excerpt}</p>
    <a href={`/blog/${slug}`} class="read-more">Read More .. <span class="arrow">&raquo;</span></a>
  </div>
</article>

<style>
  .blog-card {
    background: transparent;
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-bottom: 1rem;
  }

  .card-image-link {
    display: block;
    overflow: hidden;
    border-radius: 12px;
  }

  .card-image {
    position: relative;
    height: 220px;
    width: 100%;
    overflow: hidden;
    border-radius: 12px;
  }

  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .card-image-link:hover .card-image img {
    transform: scale(1.05);
  }

  .card-content {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 0;
  }

  .date {
    font-size: 0.85rem;
    color: #555;
    display: block;
  }

  h3 {
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.4;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  h3 a {
    color: #1a365d;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  h3 a:hover {
    color: #0A5EB0;
  }

  p {
    color: #777;
    font-size: 0.9rem;
    margin: 0;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-more {
    display: inline-flex;
    align-items: center;
    align-self: flex-start;
    padding: 0.5rem 0.75rem;
    border: 1px solid #4a4a4a;
    color: #4a4a4a;
    text-decoration: none;
    font-size: 0.85rem;
    margin-top: 0.5rem;
    transition: all 0.2s ease;
  }

  .read-more:hover {
    background-color: #f9fafb;
    border-color: #111;
  }

  .arrow {
    color: #e11d48;
    margin-left: 4px;
    font-size: 1.1rem;
    line-height: 1;
  }
</style>
