---
const currentYear = new Date().getFullYear();
import whiteLogo from '../assets/logo/sanjay-swamy-white logo.png';
---

<footer class="footer">
  <div class="footer-main">
    <div class="container">
      <div class="footer-layout">
        <!-- Brand & Contact Column -->
        <div class="footer-brand-col">
          <div class="footer-logo">
            <img src={whiteLogo.src} alt="Dr. Sanjay Swamy" class="footer-logo-img" width="220" />
          </div>
          <p class="footer-desc">Every Child Deserves <span class="highlight">the Best Care</span>. Comprehensive pediatric services by Dr. Sanjay D Swamy.</p>
          
          <div class="footer-contact-info">
            <a href="tel:+919108091744" class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
              </svg>
              <span>+91 91080 91744</span>
            </a>
            <a href="mailto:drsanjaydswamy@gmail.com" class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                <polyline points="22,6 12,13 2,6"/>
              </svg>
              <span>drsanjaydswamy@gmail.com</span>
            </a>
            <div class="contact-item">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
              <span>Navami Krishna, near Hosa Road, Electronic City, Bengaluru - 560100</span>
            </div>
          </div>
        </div>

        <!-- Links Columns -->
        <div class="footer-links-grid">
          <div class="footer-col">
            <h4>Quick Links</h4>
            <ul>
              <li><a href="/">Home</a></li>
              <li><a href="/about">About Us</a></li>
              <li><a href="/services">Services</a></li>
              <li><a href="/blog">Blog</a></li>
              <li><a href="/contact">Contact</a></li>
              <li><a href="/appointment">Book Appointment</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>Our Services</h4>
            <ul>
              <li><a href="/services/general-pediatrics">General Pediatrics</a></li>
              <li><a href="/services/picu">Pediatric Intensive Care</a></li>
              <li><a href="/services/growth-and-development">Growth & Development</a></li>
              <li><a href="/services/vaccinations">Vaccinations</a></li>
              <li><a href="/services/emergency">Emergency Care</a></li>
            </ul>
          </div>

          <div class="footer-col">
            <h4>Resources</h4>
            <ul>
              <li><a href="/faqs">FAQs</a></li>
              <li><a href="/testimonials">Testimonials</a></li>
              <li><a href="/resources">Resources</a></li>
              <li><a href="/privacy-policy">Privacy Policy</a></li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Map Section -->
  <div class="footer-map-section">
    <div class="container">
      <div class="map-container">
            <iframe
              src="https://maps.google.com/maps?q=Dr+Sanjay+Swamy,+Navami+Krishna,+near+Hosa+Road,+Chennakeshava+Nagar,+Pragathi+Nagar,+Electronic+City,+Bengaluru,+Karnataka+560100&t=&z=15&ie=UTF8&iwloc=&output=embed"
              width="100%"
              height="300"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              title="Dr Sanjay Swamy Clinic Location">
            </iframe>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-content">
      <p class="copyright">© {currentYear} Dr. Sanjay D Swamy. All rights reserved.</p>
      
      <div class="footer-bottom-links">
        <a href="/privacy-policy">Privacy Policy</a>
        <a href="/faqs">FAQs</a>
        <a href="/contact">Contact</a>
      </div>

      <div class="branding-credit">
        <span>Made & Designed by <a href="https://brandingpioneers.com/" target="_blank" rel="noopener noreferrer">Branding Pioneers</a></span>
      </div>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: #2A3335;
    color: #e2e8f0;
    padding-top: 5rem;
    font-size: 0.95rem;
  }

  .footer-layout {
    display: grid;
    grid-template-columns: minmax(auto, 300px) 1fr;
    gap: 5rem;
    margin-bottom: 3rem;
  }

  .footer-brand-col {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  .footer-desc {
    font-size: 1rem;
    line-height: 1.6;
    color: #cbd5e1;
    max-width: 350px;
    margin: 0;
  }

  .highlight {
    color: #0A97B0;
  }

  .footer-contact-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-item {
    display: flex;
    align-items: center;
    gap: 1rem;
    color: #e2e8f0;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .contact-item:hover {
    color: #0A97B0;
    transform: translateX(5px);
  }

  .contact-item svg {
    color: #0A97B0;
    width: 20px;
    height: 20px;
  }

  .footer-links-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .footer-col h4 {
    font-size: 1.1rem;
    font-weight: 600;
    color: white;
    margin-bottom: 1.5rem;
  }

  .footer-col ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-col a {
    color: #cbd5e1;
    text-decoration: none;
    transition: color 0.2s ease;
    display: inline-block;
  }

  .footer-col a:hover {
    color: #0A97B0;
  }

  /* Map Section */
  .footer-map-section {
    padding: 0 0 2rem 0;
  }

  .footer-map-section .map-container {
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 4px 20px rgba(0,0,0,0.2);
  }

  .footer-map-section iframe {
    display: block;
    filter: grayscale(20%);
    transition: filter 0.3s ease;
  }

  .footer-map-section .map-container:hover iframe {
    filter: grayscale(0%);
  }

  /* Footer Bottom */
  .footer-bottom {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding: 2rem 0;
    margin-top: 2rem;
  }

  .footer-bottom-content {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 1.5rem;
  }

  .copyright {
    color: #94a3b8;
    font-size: 0.9rem;
    margin: 0;
    text-align: left;
  }

  .footer-bottom-links {
    display: flex;
    gap: 2rem;
    justify-self: center;
  }

  .footer-bottom-links a {
    color: #94a3b8;
    text-decoration: none;
    font-size: 0.9rem;
    transition: color 0.2s ease;
  }

  .footer-bottom-links a:hover {
    color: white;
  }

  .branding-credit {
    color: #94a3b8;
    font-size: 0.9rem;
    justify-self: end;
  }

  .branding-credit a {
    color: #0A97B0;
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .branding-credit a:hover {
    color: white;
  }

  @media (max-width: 968px) {
    .footer-layout {
      grid-template-columns: 1fr;
      gap: 3rem;
    }

    .footer-links-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .footer-links-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 3rem 1.5rem;
    }

    .footer-bottom-content {
      display: flex;
      flex-direction: column;
      text-align: center;
      gap: 1.5rem;
    }

    .footer-bottom-links {
      justify-self: unset;
      justify-content: center;
    }

    .branding-credit {
      justify-self: unset;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .footer-links-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
