RewriteEngine On
RewriteBase /

# 1. Redirect /index.html to /
RewriteCond %{THE_REQUEST} \s/index\.html\s [NC]
RewriteRule ^index\.html$ / [R=301,L]

# 2. Redirect /dist/ URLs to clean URLs (only for actual client requests)
RewriteCond %{THE_REQUEST} \s/dist/
RewriteRule ^dist/(.*)$ /$1 [R=301,L]

# 3. Homepage
RewriteRule ^$ dist/index.html [END]

# 4. Load files from dist internally
RewriteCond %{REQUEST_URI} !^/dist/
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ dist/$1 [END]